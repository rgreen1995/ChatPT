# Streamlit Secrets Configuration
# Copy this file to `secrets.toml` and fill in your actual values
#
# For local development: This file should be at .streamlit/secrets.toml
# For Streamlit Cloud: Add these values in app settings under "Secrets"

# ========================================
# REQUIRED - AI Model
# ========================================
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY = "sk-ant-api03-YOUR_KEY_HERE"

# ========================================
# OPTIONAL - Alternative AI Providers
# ========================================
# Uncomment if using OpenAI
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY = "sk-proj-YOUR_KEY_HERE"

# Uncomment if using Google Gemini
# Get from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY = "AIza_YOUR_KEY_HERE"

# ========================================
# OPTIONAL - Google OAuth (Desktop only)
# ========================================
# Google OAuth works best on desktop browsers
# Mobile users will default to email/password login
#
# Get from: https://console.cloud.google.com
# Setup guide: Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID = "YOUR_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "GOCSPX-YOUR_SECRET"
GOOGLE_REDIRECT_URI = "http://localhost:8501"  # Change for production
COOKIE_SECRET_KEY = "your-random-secret-key-here"  # Generate a random string

# ========================================
# OPTIONAL - Supabase (Cloud Database)
# ========================================
# Recommended for production deployments
# Falls back to SQLite if not configured
#
# Get from: https://supabase.com/dashboard/project/_/settings/api
# Setup guide: See SUPABASE_SETUP.md
# SUPABASE_URL = "https://your-project-id.supabase.co"
# SUPABASE_KEY = "your-anon-public-key-here"

# ========================================
# OPTIONAL - Email Service (Welcome Emails)
# ========================================
# Send professional welcome emails to new users
# Signup works fine without this configured
#
# Get from: https://resend.com/api-keys
# RESEND_API_KEY = "re_YOUR_KEY_HERE"
# RESEND_FROM_EMAIL = "ChatPT <noreply@yourdomain.com>"

# ========================================
# Notes
# ========================================
# - Only ANTHROPIC_API_KEY is required to run the app
# - All other services are optional enhancements
# - SQLite database is used by default (no Supabase needed)
# - Email/password auth works without Google OAuth
# - Signup works without email service
